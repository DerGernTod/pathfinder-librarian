{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "tabWidth": 4,
    "useTabs": false,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "semi": true,
    "printWidth": 100,
    "trailingComma": "all",
    "bracketSpacing": true,
    "endOfLine": "lf",
    "insertFinalNewline": true,
    "sortImports": true,
    "sortPackageJson": true,
    "ignorePatterns": ["node_modules/**", "dist/**", "build/**", "coverage/**"]
}
