{
    "name": "pathfinder-librarian",
    "version": "1.0.0",
    "description": "LLM-Powered Pathfinder Assistant",
    "keywords": [
        "pathfinder",
        "rpg"
    ],
    "license": "MIT",
    "author": "github@raudner.dev",
    "type": "module",
    "main": "server/index.js",
    "scripts": {
        "start": "bun run --hot ./server/index.js --development",
        "serve": "bun run ./server/index.js --development",
        "lint": "oxlint",
        "format": "oxfmt",
        "test": "bun test",
        "check": "tsgo -p jsconfig.json --noEmit",
        "e2e": "playwright test",
        "e2e-local": "playwright test --project=chromium --retries=0 --ui"
    },
    "dependencies": {
        "@hono/zod-validator": "0.7.6",
        "@shoelace-style/shoelace": "2.20.1",
        "hono": "4.12.14",
        "lit": "3.3.2",
        "lit-element": "4.2.2",
        "lit-html": "3.3.2",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@happy-dom/global-registrator": "20.9.0",
        "@playwright/test": "1.59.1",
        "@testing-library/dom": "10.4.1",
        "@types/bun": "1.3.13",
        "@typescript/native-preview": "7.0.0-dev.20260426.1",
        "oxfmt": "0.46.0",
        "oxlint": "1.61.0",
        "playwright": "1.59.1"
    }
}
