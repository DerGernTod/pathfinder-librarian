{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "env": {
        "es2022": true,
        "node": true,
        "browser": true
    },
    "ignorePatterns": [
        "node_modules/**",
        "dist/**",
        "build/**",
        "coverage/**"
    ],
    "plugins": [
        "typescript",
        "import"
    ],
    "rules": {
        "no-unused-vars": "error",
        "no-undef": "error",
        "no-empty": "error",
        "no-console": "warn",
        "no-default-export": "error",
        "eqeqeq": "error",
        "curly": "error",
        "sort-imports": "error",
        "@typescript-eslint/no-explicit-any": [
            "error",
            {
                "fixToUnknown": true
            }
        ]
    }
}